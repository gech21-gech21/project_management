generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////
// MODELS
///////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  fullName  String
  username  String   @unique
  avatarUrl String?
  role      Role     @default(USER)
  status    UserStatus @default(ACTIVE)

  // Email verification fields
  emailVerified           DateTime?
  verificationToken       String? @unique
  verificationTokenExpiry DateTime?

  // Department membership
  departmentId String?
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id])

  // Project relations
  projectsManaged Project[]       @relation("ProjectManager")
  createdProjects Project[]       @relation("CreatedProjects")
  projectMembers  ProjectMember[]

  // Task relations
  tasksAssigned Task[]        @relation("AssignedTasks")
  tasksCreated  Task[]        @relation("CreatedTasks")
  taskChanges   TaskHistory[]

  // Team relations
  teamMemberships TeamMember[]
  ledTeams        Team[]       @relation("TeamLead")

  // Other relations
  comments           Comment[]
  timeLogs           TimeLog[]
  notifications      Notification[]
  uploadedFiles      Attachment[]
  managedDepartments Department[]   @relation("DepartmentManager")

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  code        String?       @unique
  status      ProjectStatus @default(PLANNING)
  priority    Priority      @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  actualCost  Float?
  progress    Int           @default(0)

  teamId      String?
  team        Team?         @relation("TeamProjects", fields: [teamId], references: [id])

  departmentId String?
  department   Department?  @relation("ProjectDepartments", fields: [departmentId], references: [id])

  projectManagerId String?
  projectManager   User?   @relation("ProjectManager", fields: [projectManagerId], references: [id])

  createdById String?
  createdBy   User?   @relation("CreatedProjects", fields: [createdById], references: [id])

  tasks          Task[]
  milestones     Milestone[]
  projectMembers ProjectMember[]
  attachments    Attachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String?
  taskCode    String? @unique

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status   TaskStatus @default(TODO)
  priority Priority   @default(MEDIUM)
  type     TaskType?

  estimatedHours Float?
  actualHours    Float?
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?

  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdById String?
  createdBy   User?   @relation("CreatedTasks", fields: [createdById], references: [id])

  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks     Task[]  @relation("Subtasks")

  position Int? @default(0)

  comments    Comment[]
  timeLogs    TimeLog[]
  attachments Attachment[]
  taskHistory TaskHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model ProjectMember {
  id        String     @id @default(uuid())
  
  projectId String
  userId    String
  
  role      MemberRole @default(MEMBER)
  joinedAt  DateTime   @default(now())
  leftAt    DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Comment {
  id      String @id @default(uuid())
  content String

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  parentCommentId String?
  parentComment   Comment?  @relation("Replies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("Replies")

  attachments Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_comments")
}

model TimeLog {
  id     String @id @default(uuid())
  
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  description     String?
  billed          Boolean   @default(false)

  createdAt DateTime @default(now())

  @@map("time_logs")
}

model Attachment {
  id               String  @id @default(uuid())
  
  filename         String
  originalFilename String?
  filePath         String
  fileSize         BigInt?
  mimeType         String?

  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  @@map("attachments")
}

model Department {
  id          String  @id @default(uuid())
  
  name        String
  code        String? @unique
  description String?

  managerId String?
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id])

  parentId       String?
  parent         Department?  @relation("Subdepartments", fields: [parentId], references: [id])
  subdepartments Department[] @relation("Subdepartments")

  users User[] @relation("UserDepartment")
  teams Team[]
  projects Project[] @relation("ProjectDepartments")

  createdAt DateTime @default(now())

  @@map("departments")
}

model TaskHistory {
  id     String @id @default(uuid())
  
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  fieldChanged String
  oldValue     String?
  newValue     String?

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  changeType ChangeType
  
  createdAt  DateTime   @default(now())

  @@map("task_history")
}

model Milestone {
  id          String  @id @default(uuid())
  
  name        String
  description String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  dueDate       DateTime?
  completedDate DateTime?
  status        MilestoneStatus @default(PENDING)
  progress      Int             @default(0)

  createdAt DateTime @default(now())

  @@map("milestones")
}

model Notification {
  id     String @id @default(uuid())
  
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  message     String
  type        NotificationType
  relatedId   String?
  relatedType String?
  isRead      Boolean          @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
}

model Team {
  id          String  @id @default(uuid())
  
  name        String
  description String?

  teamLeadId String?
  teamLead   User?   @relation("TeamLead", fields: [teamLeadId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  members  TeamMember[]
  projects Project[] @relation("TeamProjects")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

model TeamMember {
  id       String    @id @default(uuid())
  
  teamId   String
  userId   String
  
  role     role  @default(MEMBER)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

///////////////////////
// ENUMS
///////////////////////

enum Role {
  USER
  TEAMLEADER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  BUG
  FEATURE
  IMPROVEMENT
  TASK
}

enum MemberRole {
  VIEWER
  CONTRIBUTOR
  DEVELOPER
  TESTER
  MEMBER
}

enum ChangeType {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  COMMENT
  DEADLINE
  STATUS_CHANGE
  MENTION
  PROJECT_UPDATE
}

enum role {
  LEADER
  MEMBER
  GUEST
}