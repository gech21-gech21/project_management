generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

///////////////////////
// MODELS
///////////////////////

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  avatarUrl    String?
  role         Role       @default(MEMBER)
  status       UserStatus @default(ACTIVE)

  // Email verification fields
  emailVerified            DateTime?
  verificationToken        String?    @unique
  verificationTokenExpiry  DateTime?

  // Department membership
  departmentId String?
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id])

  // Project relations
  projectsManaged Project[]       @relation("ProjectManager")
  createdProjects Project[]       @relation("CreatedProjects")
  projectMembers  ProjectMember[]

  // Task relations
  tasksAssigned Task[]        @relation("AssignedTasks")
  tasksCreated  Task[]        @relation("CreatedTasks")
  taskChanges   TaskHistory[]

  // Team relations
  teamMemberships TeamMember[]
  ledTeams        Team[]       @relation("TeamLead")

  // Other relations
  comments           Comment[]
  timeLogs           TimeLog[]
  notifications      Notification[]
  uploadedFiles      Attachment[]
  managedDepartments Department[]   @relation("DepartmentManager")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  @@map("users")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  code        String?       @unique
  status      ProjectStatus @default(PLANNING)
  priority    Priority      @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  actualCost  Float?
  progress    Int           @default(0)

  // Project Manager relation
  projectManagerId String?
  projectManager   User?   @relation("ProjectManager", fields: [projectManagerId], references: [id])

  // Created by relation
  createdById String?
  createdBy   User?   @relation("CreatedProjects", fields: [createdById], references: [id])

  // Relations
  tasks          Task[]
  milestones     Milestone[]
  projectMembers ProjectMember[]
  attachments    Attachment[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String?
  taskCode    String? @unique

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Task attributes
  status   TaskStatus @default(TODO)
  priority Priority   @default(MEDIUM)
  type     TaskType?

  // Time tracking
  estimatedHours Float?
  actualHours    Float?
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?

  // Assigned to relation
  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  // Created by relation
  createdById String?
  createdBy   User?   @relation("CreatedTasks", fields: [createdById], references: [id])

  // Subtask relations (self-reference)
  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks     Task[]  @relation("Subtasks")

  // Order/position
  position Int? @default(0)

  // Relations
  comments    Comment[]
  timeLogs    TimeLog[]
  attachments Attachment[]
  taskHistory TaskHistory[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model ProjectMember {
  id        String     @id @default(uuid())
  
  // Relations
  projectId String
  userId    String
  
  // Member attributes
  role      MemberRole @default(MEMBER)
  joinedAt  DateTime   @default(now())
  leftAt    DateTime?

  // Relations with cascade delete
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint
  @@unique([projectId, userId])
  @@map("project_members")
}

model Comment {
  id      String @id @default(uuid())
  content String

  // Task relation
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Reply relations (self-reference)
  parentCommentId String?
  parentComment   Comment?  @relation("Replies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("Replies")

  // Attachments as JSON
  attachments Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_comments")
}

model TimeLog {
  id     String @id @default(uuid())
  
  // Relations
  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  // Time tracking
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  description     String?
  billed          Boolean   @default(false)

  // Timestamp
  createdAt DateTime @default(now())

  @@map("time_logs")
}

model Attachment {
  id               String  @id @default(uuid())
  
  // File metadata
  filename         String
  originalFilename String?
  filePath         String
  fileSize         BigInt?
  mimeType         String?

  // Uploader relation
  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  // Optional task relation
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id])

  // Optional project relation
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  // Timestamp
  createdAt DateTime @default(now())

  @@map("attachments")
}

model Department {
  id          String  @id @default(uuid())
  
  // Department info
  name        String
  code        String? @unique
  description String?

  // Manager relation
  managerId String?
  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id])

  // Parent department relation (self-reference)
  parentId       String?
  parent         Department?  @relation("Subdepartments", fields: [parentId], references: [id])
  subdepartments Department[] @relation("Subdepartments")

  // Relations
  users User[] @relation("UserDepartment")
  teams Team[]

  // Timestamp
  createdAt DateTime @default(now())

  @@map("departments")
}

model TaskHistory {
  id     String @id @default(uuid())
  
  // Task relation
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Change details
  fieldChanged String
  oldValue     String?
  newValue     String?

  // User who made the change
  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  // Change type
  changeType ChangeType
  
  // Timestamp
  createdAt  DateTime   @default(now())

  @@map("task_history")
}

model Milestone {
  id          String  @id @default(uuid())
  
  // Milestone info
  name        String
  description String?

  // Project relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Dates and status
  dueDate       DateTime?
  completedDate DateTime?
  status        MilestoneStatus @default(PENDING)
  progress      Int             @default(0)

  // Timestamp
  createdAt DateTime @default(now())

  @@map("milestones")
}

model Notification {
  id     String @id @default(uuid())
  
  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notification content
  title       String
  message     String
  type        NotificationType
  relatedId   String?
  relatedType String?
  isRead      Boolean          @default(false)

  // Timestamp
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Team {
  id          String  @id @default(uuid())
  
  // Team info
  name        String
  description String?

  // Team lead relation
  teamLeadId String?
  teamLead   User?   @relation("TeamLead", fields: [teamLeadId], references: [id])

  // Department relation
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Members relation
  members TeamMember[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teams")
}

model TeamMember {
  id       String    @id @default(uuid())
  
  // Relations
  teamId   String
  userId   String
  
  // Member attributes
  role     TeamRole  @default(MEMBER)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  // Relations with cascade delete
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint
  @@unique([teamId, userId])
  @@map("team_members")
}

///////////////////////
// ENUMS
///////////////////////

enum Role {
  ADMIN
  PROJECT_MANAGER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  BUG
  FEATURE
  IMPROVEMENT
  TASK
}

enum MemberRole {
  VIEWER
  CONTRIBUTOR
  DEVELOPER
  TESTER
  MEMBER
}

enum ChangeType {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  TASK_ASSIGNED
  COMMENT
  DEADLINE
  STATUS_CHANGE
  MENTION
  PROJECT_UPDATE
}

enum TeamRole {
  LEADER
  MEMBER
  GUEST
}